  "description": "Digital Maturity & Cybersecurity Assessment System",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/index.js",
    "server": "node --watch server/index.js",
