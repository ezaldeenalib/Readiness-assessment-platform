# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maturity_assessment
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_BASE64_STRING
JWT_EXPIRES_IN=15m

# CSRF — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
CSRF_SECRET=REPLACE_WITH_64_BYTE_RANDOM_BASE64_STRING

# Server
PORT=3000
NODE_ENV=development

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:5173

# Health endpoint — comma-separated IPs allowed to access /health
HEALTH_ALLOWED_IPS=127.0.0.1,::1
